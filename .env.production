# ManimCat Production Environment Variables
# 生产环境配置文件

# ===========================================
# 服务配置 / Service Configuration
# ===========================================

# Node 环境（请勿修改）
NODE_ENV=production

# 服务端口
PORT=3000

# ===========================================
# Redis 配置 / Redis Configuration
# ===========================================

# Redis 主机地址（Docker Compose 中为 "redis"）
REDIS_HOST=redis

# Redis 端口
REDIS_PORT=6379

# Redis 密码（可选，如果 Redis 需要认证）
# REDIS_PASSWORD=

# Redis 数据库编号
REDIS_DB=0

# ===========================================
# OpenAI 配置 / OpenAI Configuration
# ===========================================

# OpenAI API Key（必填）
# 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI 模型选择
# 默认使用 glm-4-flash（实际支持任何 OpenAI 兼容模型）
# 示例: gpt-4o-mini, gpt-4-turbo, glm-4-flash 等
OPENAI_MODEL=glm-4-flash

# 自定义 API 端点（可选）
# 如果使用 OpenAI 官方 API，请留空
# 示例 - Together AI: https://api.together.xyz/v1
# 示例 - LocalAI: http://localhost:8080/v1
CUSTOM_API_URL=

# ===========================================
# 安全配置 / Security Configuration
# ===========================================

# API 认证密钥（可选）
# 设置后将启用 API 认证保护
# 如果不需要认证，请留空或删除此行
# MANIMCAT_API_KEY=

# 多个 API 认证密钥（可选）
# 与 MANIMCAT_API_KEY 合并去重，支持逗号或换行分隔
# MANIMCAT_API_KEYS=

# ===========================================
# 日志配置 / Logging Configuration
# ===========================================

# 日志级别（debug/info/warn/error）
LOG_LEVEL=info

# 生产环境仅输出任务摘要日志（每任务一条）
# true: 仅输出 _logType=job_summary
# false: 保持详细日志
PROD_SUMMARY_LOG_ONLY=true

# 流式请求是否尝试记录 usage token（需上游支持）
# 若网关不支持会自动回退，不影响请求继续执行
OPENAI_STREAM_INCLUDE_USAGE=true

# ===========================================
# 显示配置 / Display Configuration
# ===========================================

# X11 虚拟显示（Xvfb 使用，请勿修改）
DISPLAY=:99
