# DESIGNER_THINKING_TOKENS: 姒傚康璁捐鑰呯殑鎬濈淮閾?token 鏁帮紙榛樿鍊硷細20000锛?# DESIGNER_THINKING_TOKENS=20000

# -----------------------------------------------------------------------------
# 搴旂敤璁剧疆
# -----------------------------------------------------------------------------
# NODE_ENV: 杩愯鐜
# - development锛堝紑鍙戠幆澧冿級
# - production锛堢敓浜х幆澧冿級
NODE_ENV=development

# LOG_LEVEL: 鏃ュ織绾у埆锛坉ebug/info/warn/error锛岄粯璁?info锛?# LOG_LEVEL=info

# PROD_SUMMARY_LOG_ONLY: 鐢熶骇鐜浠呰緭鍑轰换鍔℃憳瑕佹棩蹇楋紙榛樿 true锛?# - true: 浠呰緭鍑?_logType=job_summary 鐨勬棩蹇楋紙姣忎换鍔′竴鏉★級
# - false: 淇濇寔鐜版湁璇︾粏鏃ュ織
# PROD_SUMMARY_LOG_ONLY=true

# -----------------------------------------------------------------------------
