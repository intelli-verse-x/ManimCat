# MANIMCAT_ROUTE_*: 鎸?ManimCat API 瀵嗛挜鏄犲皠涓婃父
# - 鐢ㄤ簬"娴嬭瘯鐢ㄦ埛 / 姝ｅ紡鐢ㄦ埛"闅旂璺敱
# - 鎸夌储寮曢厤瀵癸細keys[i] -> apiUrls[i] + apiKeys[i] + models[i]
# - 鑻ユ煇瀛楁鍙～ 1 涓€硷紝浼氬鐢ㄥ埌鎵€鏈夌储寮?# - model 鐣欑┖琛ㄧず绂佺敤璇?key锛堝悗绔彲杈句絾鏃犲彲鐢ㄦā鍨嬶級
# MANIMCAT_ROUTE_KEYS=user_key_a,user_key_b
# MANIMCAT_ROUTE_API_URLS=https://api-a.example.com/v1,https://api-b.example.com/v1
# MANIMCAT_ROUTE_API_KEYS=sk-a,sk-b
